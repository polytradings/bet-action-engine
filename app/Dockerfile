## syntax=docker/dockerfile:1.7

FROM gradle:8.10.2-jdk21 AS builder

WORKDIR /workspace

# Copy source and build files.
COPY . .

# Build distribution with all runtime dependencies in /build/install/<app-name>/lib
RUN --mount=type=cache,target=/home/gradle/.gradle \
	gradle --no-daemon clean installDist


FROM gcr.io/distroless/java21-debian12:nonroot

WORKDIR /app

# Copy runtime libs generated by installDist.
COPY --from=builder /workspace/build/install/bet-action-engine/lib/ ./lib/

# Distroless nonroot image already runs as an unprivileged user.
ENTRYPOINT ["java", "-cp", "/app/lib/*", "com.polytradings.betaction.BetActionApplicationKt"]
